---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, date, thumbnail } = post.data;
---

<BaseLayout title={title} description={description}>
  <article class="section section--panel">
    <div class="container">
      <p class="post__back"><a href="/blog/">← All posts</a></p>
      <h1>{title}</h1>
      <time class="post__date muted" datetime={date.toISOString()}>
        {formatDate(date)}
      </time>

      {
        thumbnail && (
          <Image class="post__hero" src={thumbnail} alt="" width={1472} />
        )
      }

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post__back {
    font-size: 0.9rem;
    margin-bottom: var(--space-6);
  }
  .post__date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: var(--space-12);
  }
  /* Title image rendered automatically from the `thumbnail` frontmatter;
     shown at its full ratio (no crop) above the body. */
  .post__hero {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  /* Article body typography. */
  .prose :global(h2) {
    margin-top: var(--space-12);
  }
  .prose :global(h3) {
    margin-top: var(--space-8);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  .prose :global(pre) {
    padding: var(--space-4);
    border-radius: var(--radius);
    overflow-x: auto;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
    /* Keep Shiki's own dark Nord background so code stays readable in both the
       light and dark site themes. */
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  /* Inline code (not inside a pre block). Raised a shade so it stays legible
     against the surface-colored article panel. */
  .prose :global(:not(pre) > code) {
    background: var(--color-raised);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 0.1rem 0.35rem;
  }
  .prose :global(blockquote) {
    margin: 0 0 var(--space-4);
    padding-left: var(--space-4);
    border-left: 3px solid var(--color-border);
    color: var(--color-muted);
  }
  .prose :global(img) {
    border-radius: var(--radius);
  }
</style>
