---
import { SITE } from '../../consts';
---

<section class="section section--panel hero">
  <div class="container container--wide hero__grid">
    <div class="hero__text">
      <h1>{SITE.title}</h1>
      <p class="hero__tagline">{SITE.tagline}</p>

      <p class="hero__mission">
        Closing the gap for everyday people<br class="hero__mission-br" />
        who just want to use technology<br class="hero__mission-br" />
        without feeling left behind.
      </p>

      <p class="hero__intro">
        Self-taught systems thinker, happiest making complicated things simpler.
      </p>

      <div class="hero__cta">
        <a class="button button--ghost" href="#contact">Get in touch</a>
      </div>
    </div>

    <img
      class="hero__photo"
      src="/michael.jpeg"
      alt="Michael Gilchrist"
      width="597"
      height="725"
    />
  </div>
</section>

<style>
  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 18rem);
    gap: var(--space-12);
    align-items: start;
  }

  .hero__text h1 {
    font-size: clamp(1.5rem, 4vw, 1.5rem);
  }

  .hero__tagline {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-top: calc(var(--space-4) * -0.5);
    /* Match the mission's bottom margin so the mission sits an equal distance
       from the tagline above it and the intro below it. */
    margin-bottom: var(--space-4);
  }

  /* The mission line: the hero's centerpiece. Larger and medium-weight so it
     reads as a confident statement rather than a shouty headline. */
  .hero__mission {
    font-size: clamp(2.5rem, 2.7vw, 2.5rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
  }

  /* Chosen line breaks for the mission ("...people / ...technology / ...").
     Only enforced once the wide container is maxed out and the line lengths
     stop changing; below that the text wraps naturally. */
  .hero__mission-br {
    display: none;
  }
  @media (min-width: 75rem) {
    .hero__mission-br {
      display: inline;
    }
  }

  .hero__intro {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-bottom: var(--space-6);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .hero__photo {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
    background: var(--color-raised);
    border: 1px solid var(--color-border);
  }

  /* Stack on smaller screens: photo becomes a compact block above the text. */
  @media (max-width: 48rem) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__photo {
      order: -1;
      max-width: 14rem;
      aspect-ratio: 1 / 1;
    }
  }
</style>
