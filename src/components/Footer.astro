---
import { SITE, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container--wide site-footer__inner">
    <p class="muted">© {year} {SITE.title}</p>
    <ul class="social">
      {
        SOCIALS.map((s) => (
          <li>
            <a href={s.href} rel="me noopener">
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-8);
  }
  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .site-footer p {
    margin: 0;
    font-size: 0.9rem;
  }
  .social {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social a {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .social a:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
